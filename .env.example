# LiveKit Config (For both Server and Agents)
# Use ws://localhost:7880 for local dev, or wss://<your-caddy-domain> for production
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# OpenAI (For GPT-4o mini and text-embeddings)
OPENAI_API_KEY=your-openai-api-key

# Deepgram (For STT and TTS)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Qdrant Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=gaply_knowledge

# Gaplytiq Backend (for function tools)
# Global fallback (if tenant-specific isn't provided)
GAPLYTIQ_BACKEND_URL=http://localhost:5000/api
# Tenant specific API URLs
INSTITUTES_API_URL=https://institute.gaplytiq.com/api
ENTERPRISES_API_URL=https://enterprises.gaplytiq.com/api

# Widget Config (CORS for Token API)
WIDGET_CORS_ORIGINS=https://institute.gaplytiq.com,http://localhost:3000,http://localhost:3001



# Bot Identity
BOT_NAME=Gaply
BOT_VOICE=aura-2-luna-en
BOT_VOICE_STT_MODEL=nova-3
